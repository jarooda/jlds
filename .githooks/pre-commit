#!/bin/sh
# JLDS pre-commit hook.
# Regenerates derived, committed artifacts and stages them so they never drift
# from their sources:
#   - registry/css/all.css  (@import list of every component stylesheet)
#   - registry/js/all.js    (core + every component behavior)
#
# Enable once per clone:  git config core.hooksPath .githooks
#
# Note: this only touches committed artifacts. Generated-but-gitignored output
# (e.g. docs/public/css from sync-css, docs/.vitepress/dist) is intentionally
# NOT handled here — it's rebuilt by the docs dev/build scripts and never committed.

set -e

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if ! command -v node >/dev/null 2>&1; then
  echo "pre-commit: node not found — skipping bundle regeneration." >&2
  exit 0
fi

# Regenerate the bundles and stage them. `git add` on an unchanged file is a
# no-op; comparing the index to HEAD afterwards reports a change whether the
# file is newly added or modified.
node registry/scripts/build-css-bundle.mjs >/dev/null
node registry/scripts/build-js-bundle.mjs >/dev/null

for f in registry/css/all.css registry/js/all.js; do
  git add "$f"
  if ! git diff --cached --quiet -- "$f"; then
    echo "pre-commit: regenerated and staged $f"
  fi
done

exit 0
